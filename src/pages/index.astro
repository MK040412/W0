---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Layout title='W0: An Open VLA for Long-Horizon Tasks'>
	<main class='outer'>
		<section class='hero'>
			<img src={`${base}/weasel-logo.png`} alt='Weasel logo' class='hero-image' />
			<div class='hero-text'>
				<h1>W0: An Open VLA for Long-Horizon Tasks</h1>
				<p class='subtitle'>
					Part of <a href='https://mk040412.github.io/Project-Weasel/'>Project Weasel</a>.
				</p>
				<a class='repo-link' href='https://github.com/MK040412/W0'>github.com/MK040412/W0</a>
			</div>
		</section>

		<section class='section'>
			<h2>Abstract</h2>
			<p class='muted'>Coming soon.</p>
		</section>

		<section class='section'>
			<h2>Method</h2>
			<p class='muted'>Coming soon.</p>
		</section>

		<section class='section'>
			<h2>Results</h2>
			<p class='muted'>Coming soon.</p>
		</section>
	</main>
</Layout>
