---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const authors = [
	{ name: 'Kang Minkyu', href: 'https://mk040412.github.io/' },
]

const links = [
	{ label: 'Project Weasel', href: 'https://mk040412.github.io/Project-Weasel/' },
]
---

<Layout
	title='W0: An Open VLA for Long-Horizon Tasks'
	pageTitle='W0'
	description='Main project of Project Weasel — first entry in the W series, an open VLA for long-horizon tasks.'
	authors={authors}
	links={links}
	hero={`${base}/weasel-logo.png`}
	heroAlt='W0 hero image'
	faviconHref={`${base}/weasel-logo.png`}
>
	<h1>Overview</h1>
	<ul>
		<li><b>W0</b> is the main project of <a href='https://mk040412.github.io/Project-Weasel/'>Project Weasel</a>.</li>
		<li>Coming soon.</li>
	</ul>

	<h1>Method</h1>
	<p class='muted'>Coming soon.</p>

	<h1>Results</h1>
	<p class='muted'>Coming soon.</p>

	<hr />
	<h1>Acknowledgement</h1>
	<p>
		Part of <a href='https://mk040412.github.io/Project-Weasel/'>Project Weasel</a>, maintained by{' '}
		<a href='https://mk040412.github.io/'>Kang Minkyu</a>.
	</p>
</Layout>
