---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const authors = [
	{ name: 'Minkyu Kang', affiliation: 'UNIST' },
	{ name: 'JinHo Kim', affiliation: 'UNIST' },
	{ name: 'Eunseop Shin', affiliation: 'UNIST' },
	{ name: 'Dayeon Hwang', affiliation: 'UNIST' },
]

const links = [
	{ label: 'Project Weasel', href: 'https://mk040412.github.io/Project-Weasel/' },
	{ label: 'Technical Report', href: `${base}/W0_Technical_Report.pdf` },
	{ label: 'Data & Model', href: 'https://huggingface.co/KMK040412' },
]

// Chain-of-thought reasoning examples (reason, then act); GT vs prediction shown.
const reasoning = [
	{ f: 'reasoning_02_comandroidchrome.gif', l: 'Chrome' },
	{ f: 'reasoning_04_ChatbotAISmartA.gif', l: 'Chatbot AI assistant' },
	{ f: 'reasoning_07_ClockZohoMeetin.gif', l: 'Clock / Zoho Meeting' },
	{ f: 'reasoning_09_comgoogleandroid.gif', l: 'Google (Android)' },
	{ f: 'reasoning_16_SimpleSmsSendRec.gif', l: 'Simple SMS' },
	{ f: 'reasoning_20_SimpleCalendarEv.gif', l: 'Simple Calendar' },
	{ f: 'reasoning_21_MarkorCreateNote.gif', l: 'Markor — create note' },
	{ f: 'reasoning_24_YoutubeThings.gif', l: 'YouTube' },
]

// One-step decoding: a single block-diffusion decode of one action (bd4, no autoregression).
const onestep = [
	{ f: 'onestep_000_SimpleSmsSend_d0.0.gif', l: 'Simple SMS Send' },
	{ f: 'onestep_002_NotesRecipeIngredien_d0.0.gif', l: 'Notes — recipe' },
	{ f: 'onestep_003_RetroPlaylistDuratio_d1.0.gif', l: 'Retro Playlist' },
	{ f: 'onestep_005_ApplockProAPPLockGua_d4.0.gif', l: 'Applock Pro' },
	{ f: 'onestep_011_ChatbotAISmartAssist_d32.0.gif', l: 'Chatbot AI assistant' },
	{ f: 'onestep_012_GooglePlayStoreSetti_d43.6.gif', l: 'Google Play Store' },
	{ f: 'onestep_016_ClockZohoMeetingX_d54.7.gif', l: 'Clock / Zoho Meeting' },
	{ f: 'onestep_019_MarkorEditNote_d62.6.gif', l: 'Markor — edit note' },
	{ f: 'onestep_020_app_d63.1.gif', l: 'App switch' },
	{ f: 'onestep_022_SimpleSmsResend_d65.6.gif', l: 'Simple SMS Resend' },
]
---

<Layout
	title='W0: A dVLM-Based GUI Agent with Block-Diffusion Mode Steering'
	pageTitle='W0 · Project Weasel'
	description='W0 (Project Weasel): a dVLM-based GUI agent with a block-discrete diffusion action head and selector-only RLVR (MSPO). Technical report, demos, data and models.'
	authors={authors}
	links={links}
	hero={`${base}/assets/hero_decode.gif`}
	heroAlt='W0 block-diffusion decoding vs autoregression on a live GUI task'
	faviconHref={`${base}/weasel-logo.png`}
>
	<p class='note muted'>
		Additional data &amp; models are released on
		<a href='https://huggingface.co/KMK040412'><b>KMK040412</b></a> (Hugging&nbsp;Face).
	</p>

	<h1>Overview</h1>
	<p>
		<b>W0</b> keeps a <b>frozen</b> screen-language backbone and bounded memory, decodes each UI
		action with a <b>block-discrete diffusion</b> head, and trains <b>only</b> a categorical mode
		selector with critic-free RLVR (<b>MSPO</b>).
	</p>
	<figure class='fig'>
		<img src={`${base}/assets/teaser.png`} alt='W0 at a glance: latency, task success, convergence' />
		<figcaption class='figcap'>
			<b>Figure&nbsp;1 — W0 at a glance.</b>
			<i>Left:</i> at the deployed block size <code>bd16</code>, block-diffusion decoding cuts
			per-chunk decode latency over an autoregressive decoder (~2.8×).
			<i>Middle:</i> selector-only W0 reaches the highest GUI task success, above SFT and the two
			critic-free RLVR baselines — <b>GRPO</b> and <b>RLOO</b> — applied to the full block-dVLM policy.
			<i>Right:</i> W0 reaches that regime with fewer verifier-driven update rounds.
			(Technical-report snapshot; numbers to be finalized.)
		</figcaption>
	</figure>

	<h1>Block diffusion vs. autoregression</h1>
	<p>
		The same UI action, decoded two ways. Autoregression emits one token per forward pass; block
		diffusion denoises the whole action chunk in parallel — fewer forward passes, lower latency, at
		matched output.
	</p>
	<div class='twoup'>
		<figure>
			<h3>Gmail action (with screen)</h3>
			<video src={`${base}/assets/cmp_gmail.mp4`} autoplay loop muted playsinline></video>
		</figure>
		<figure>
			<h3>Action decoding (clean view)</h3>
			<video src={`${base}/assets/cmp_type.mp4`} autoplay loop muted playsinline></video>
		</figure>
	</div>
	<p class='muted figcap'>
		Block diffusion fills the action in parallel — in this example ≈3.8× faster and ≈3.8× fewer
		forward passes (12 vs. 45 NFE), at the same decoded action.
	</p>

	<h1>Reasoning, then acting</h1>
	<p class='muted'>W0 can emit a chain-of-thought before the action. Each example shows the
		model's reasoning and the decoded action on a live AndroidWorld screen (ground-truth target
		vs. the model's prediction). Click any example to enlarge and read the full reasoning.</p>
	<div class='gallery gallery-wide'>
		{reasoning.map((g) => (
			<figure class='gcard'>
				<img loading='lazy' src={`${base}/assets/reasoning/${g.f}`} alt={g.l} />
				<figcaption>{g.l}</figcaption>
			</figure>
		))}
	</div>

	<h1>One-step decoding</h1>
	<p class='muted'>The same agent without chain-of-thought: a single block-diffusion decode
		(bd4, no autoregression) emits one UI action in one step. Click to enlarge.</p>
	<div class='gallery'>
		{onestep.map((g) => (
			<figure class='gcard'>
				<img loading='lazy' src={`${base}/assets/onestep/${g.f}`} alt={g.l} />
				<figcaption>{g.l}</figcaption>
			</figure>
		))}
	</div>

	<h1>Team</h1>
	<figure class='team-photo'>
		<img src={`${base}/assets/team.jpg`} alt='Project Weasel team' />
	</figure>
	<div class='team-names'>
		<div class='nm'>Dayeon Hwang</div>
		<div class='nm'>Eunseop Shin</div>
		<div class='nm'>Minkyu Kang</div>
		<div class='nm'>JinHo Kim</div>
	</div>

	<div id='lightbox' class='lightbox' role='dialog' aria-label='enlarged demo'>
		<img id='lightbox-img' src='' alt='' />
	</div>
</Layout>

<style>
	.note { text-align: center; margin-top: -6px; }
	.fig { max-width: 720px; margin: 18px auto; }
	.fig img { width: 100%; height: auto; display: block; border-radius: 6px; border: 1px solid var(--border); }
	.figcap { font-size: 15px; color: var(--muted); text-align: center; margin-top: 10px; }
	.twoup { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 14px 0; }
	.twoup figure { margin: 0; }
	.twoup video { width: 100%; border-radius: 6px; border: 1px solid var(--border); display: block; }
	.twoup h3 { text-align: center; margin: 0 0 8px; }
	.gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; margin: 14px 0; }
	.gallery-wide { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
	.gcard { margin: 0; }
	.gcard img { width: 100%; border-radius: 8px; border: 1px solid var(--border); display: block; cursor: zoom-in; transition: transform .12s ease; }
	.gcard img:hover { transform: scale(1.03); }
	.gcard figcaption { font-size: 12px; color: var(--muted); text-align: center; margin-top: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.team-photo { max-width: 600px; margin: 16px auto; }
	.team-photo img { width: 100%; height: auto; display: block; border-radius: 8px; border: 1px solid var(--border); }
	.team-names { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; max-width: 600px; margin: 10px auto 0; text-align: center; }
	.team-names .nm { font-weight: 700; }
	/* click-to-enlarge lightbox for the demo gallery */
	.lightbox { position: fixed; inset: 0; background: rgba(10, 16, 28, 0.88); display: none;
		align-items: center; justify-content: center; z-index: 1000; cursor: zoom-out; padding: 24px; }
	.lightbox.open { display: flex; }
	.lightbox img { max-width: 92vw; max-height: 92vh; width: auto; height: auto; border-radius: 10px;
		box-shadow: 0 10px 60px rgba(0, 0, 0, 0.6); }
	@media (max-width: 700px) {
		.twoup { grid-template-columns: 1fr; }
		.team-names { grid-template-columns: repeat(2, 1fr); }
	}
</style>

<script>
	const lb = document.getElementById('lightbox')
	const lbImg = document.getElementById('lightbox-img')
	if (lb && lbImg) {
		document.querySelectorAll('.gcard img').forEach((img) => {
			img.addEventListener('click', () => {
				lbImg.setAttribute('src', img.getAttribute('src') || '')
				lbImg.setAttribute('alt', img.getAttribute('alt') || '')
				lb.classList.add('open')
			})
		})
		const close = () => {
			lb.classList.remove('open')
			lbImg.setAttribute('src', '')
		}
		lb.addEventListener('click', close)
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') close()
		})
	}
</script>
