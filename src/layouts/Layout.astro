---
type Author = { name: string; href?: string; affiliation?: string }
type LinkItem = { label: string; href: string }

interface Props {
	pageTitle?: string
	title: string
	authors?: Author[]
	links?: LinkItem[]
	hero?: string
	heroVideo?: string
	heroAlt?: string
	description?: string
	faviconHref?: string
}

const {
	pageTitle,
	title,
	authors = [],
	links = [],
	hero,
	heroVideo,
	heroAlt = title,
	description,
	faviconHref,
} = Astro.props
---

<!doctype html>
<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width,initial-scale=1' />
		{faviconHref && <link rel='icon' type='image/png' href={faviconHref} />}
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			rel='stylesheet'
			href='https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,300i,400,400i,600,600i,700,700i&display=swap'
		/>
		<link
			rel='stylesheet'
			href='https://fonts.googleapis.com/css?family=Source+Code+Pro:400,600&display=swap'
		/>
		<title>{pageTitle || title}</title>
		{description && <meta name='description' content={description} />}
		<meta property='og:title' content={pageTitle || title} />
		{description && <meta property='og:description' content={description} />}
	</head>
	<body>
		<main class='page'>
			<h1 class='page-title'>{title}</h1>

			{authors.length > 0 && (
				<ul class='author-list'>
					{authors.map((a) => (
						<li>
							{a.href ? <a href={a.href}>{a.name}</a> : <span>{a.name}</span>}
							{a.affiliation && (
								<>
									<br />
									<span class='affiliation'>{a.affiliation}</span>
								</>
							)}
						</li>
					))}
				</ul>
			)}

			{links.length > 0 && (
				<ul class='link-list'>
					{links.map((l) => (
						<li>
							<a href={l.href}>
								<span class='link-button'>{l.label}</span>
							</a>
						</li>
					))}
				</ul>
			)}

			{(heroVideo || hero) && (
				<div class='hero-container'>
					{heroVideo ? (
						<video class='hero-media' autoplay loop muted playsinline>
							<source src={heroVideo} type='video/mp4' />
						</video>
					) : (
						<img class='hero-media' src={hero} alt={heroAlt} />
					)}
				</div>
			)}

			<slot />

			<hr />
			<p class='footer-credit'>
				The website template was partly borrowed from{' '}
				<a href='http://mgharbi.com/'>Michaël Gharbi</a> and{' '}
				<a href='https://jonbarron.info/'>Jon Barron</a>.
			</p>
		</main>
	</body>
</html>

<style is:global>
	:root {
		--link: #598be7;
		--link-hover: #9bb9f1;
		--fg: #000;
		--bg: #fff;
		--muted: #555;
		--border: #e6e6e6;
		--code-bg: #f6f8fa;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--fg);
	}

	body {
		font-family: 'Source Sans Pro', 'Lato', Verdana, Helvetica, sans-serif;
		font-size: 18px;
		font-weight: 400;
		-webkit-font-smoothing: antialiased;
		line-height: 1.55;
	}

	a,
	a:focus {
		color: var(--link);
		text-decoration: none;
	}
	a:hover {
		color: var(--link-hover);
		text-decoration: none;
	}

	strong,
	b {
		font-weight: 700;
	}

	.page {
		max-width: 960px;
		margin: 0 auto;
		padding: 30px 20px 80px;
	}

	.page-title {
		text-align: center;
		font-weight: 700;
		font-size: 56px;
		margin: 30px 0 24px;
		line-height: 1.15;
	}

	.author-list,
	.link-list {
		list-style: none;
		padding: 0;
		margin: 0 0 20px 0;
		text-align: center;
	}

	.author-list > li {
		display: inline-block;
		margin: 0 12px 12px;
		text-align: center;
		vertical-align: top;
		line-height: 1.3;
	}

	.author-list .affiliation {
		color: var(--muted);
		font-size: 0.92em;
	}

	.link-list > li {
		display: inline-block;
		margin: 0 6px;
	}

	.link-button {
		display: inline-block;
		margin: 10px 0;
		padding: 4px 14px;
		font-size: 22px;
		font-weight: 500;
		color: var(--link);
	}
	a:hover .link-button {
		color: var(--link-hover);
	}

	.hero-container {
		max-width: 800px;
		margin: 30px auto;
	}

	.hero-media {
		width: 100%;
		height: auto;
		display: block;
		margin: 0 auto;
		border-radius: 6px;
	}

	h1 {
		font-weight: 300;
		margin: 36px 0 16px;
		font-size: 44px;
	}

	h2 {
		font-weight: 300;
		margin: 28px 0 12px;
		font-size: 30px;
	}

	h3 {
		font-weight: 600;
		margin: 20px 0 10px;
		font-size: 22px;
	}

	p,
	ul,
	ol {
		margin: 0 0 12px 0;
	}

	ul li,
	ol li {
		margin-bottom: 6px;
	}

	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 40px 0 20px;
	}

	pre.codebox,
	pre {
		font-size: 15px;
		background: var(--code-bg);
		border: none;
		border-radius: 6px;
		padding: 16px;
		overflow-x: auto;
		margin: 12px 0;
	}

	code {
		font-family: 'Source Code Pro', ui-monospace, monospace;
		background: var(--code-bg);
		padding: 1px 4px;
		border-radius: 3px;
		font-size: 0.95em;
	}

	pre code {
		padding: 0;
		background: transparent;
		font-size: 1em;
	}

	.muted {
		color: var(--muted);
	}

	.footer-credit {
		color: var(--muted);
		text-align: center;
		font-size: 14px;
		margin-top: 16px;
	}

	@media (max-width: 700px) {
		body {
			font-size: 16px;
		}
		.page-title {
			font-size: 38px;
		}
		h1 {
			font-size: 32px;
		}
		h2 {
			font-size: 24px;
		}
		.link-button {
			font-size: 18px;
		}
	}
</style>
